rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    function isCoach() {
      return signedIn() &&
        firestore.exists(/databases/(default)/documents/coaches/$(request.auth.uid));
    }

    function isStaff() {
      return isAdmin() || isCoach();
    }

    match /coach-videos/{coachUid}/{allPaths=**} {
      allow read: if true;
      allow write: if isStaff();
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
