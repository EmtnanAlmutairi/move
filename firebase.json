{
  "firestore": {
    "rules": "firestore.rules"
  },
  "hosting": {
    "public": ".",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/move",
        "destination": "/move-app.html"
      },
      {
        "source": "/coach",
        "destination": "/coach-portal.html"
      },
      {
        "source": "/admin-move",
        "destination": "/admin-move.html"
      },
      {
        "source": "/admin",
        "destination": "/admin.html"
      }
    ]
  }
}
