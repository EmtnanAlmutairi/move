{
    "firestore":  {
                      "rules":  "firestore.rules"
                  },
    "hosting":  {
                    "public":  ".",
                    "rewrites":  [
                                     {
                                         "source":  "/admin",
                                         "destination":  "/admin.html"
                                     }
                                 ],
                    "ignore":  [
                                   "firebase.json",
                                   ".firebaserc",
                                   ".firebase-config/**",
                                   ".git/**",
                                   ".vscode/**",
                                   "**/.*",
                                   "**/node_modules/**",
                                   "functions/**",
                                   "README.md",
                                   "firestore.rules",
                                   "server*.log",
                                   "serve.ps1"
                               ]
                }
}
