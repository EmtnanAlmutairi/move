rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /waitlist/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly(["email", "source", "createdAt"]) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.source == "landing-page" &&
        request.resource.data.createdAt == request.time;
    }

    match /traineeInterests/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "goal",
          "fitnessLevel",
          "trainingLocation",
          "equipment",
          "healthNotes",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 7 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() >= 3 &&
        request.resource.data.goal.size() <= 40 &&
        request.resource.data.fitnessLevel is string &&
        request.resource.data.fitnessLevel.size() >= 3 &&
        request.resource.data.fitnessLevel.size() <= 20 &&
        request.resource.data.trainingLocation is string &&
        request.resource.data.trainingLocation.size() >= 3 &&
        request.resource.data.trainingLocation.size() <= 20 &&
        request.resource.data.equipment is string &&
        request.resource.data.equipment.size() >= 2 &&
        request.resource.data.equipment.size() <= 1000 &&
        request.resource.data.healthNotes is string &&
        request.resource.data.healthNotes.size() <= 1000 &&
        request.resource.data.source == "landing-page-trainee" &&
        request.resource.data.createdAt == request.time;
    }

    match /coachApplications/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "yearsExperience",
          "specialization",
          "certifications",
          "coachingType",
          "coachingLocation",
          "experienceDetails",
          "availability",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 7 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.yearsExperience is number &&
        request.resource.data.yearsExperience >= 0 &&
        request.resource.data.yearsExperience <= 50 &&
        request.resource.data.specialization is string &&
        request.resource.data.specialization.size() >= 3 &&
        request.resource.data.specialization.size() <= 40 &&
        request.resource.data.certifications is string &&
        request.resource.data.certifications.size() >= 2 &&
        request.resource.data.certifications.size() <= 300 &&
        request.resource.data.coachingType is string &&
        request.resource.data.coachingType.size() >= 3 &&
        request.resource.data.coachingType.size() <= 20 &&
        request.resource.data.coachingLocation is string &&
        request.resource.data.coachingLocation.size() >= 3 &&
        request.resource.data.coachingLocation.size() <= 30 &&
        request.resource.data.experienceDetails is string &&
        request.resource.data.experienceDetails.size() >= 10 &&
        request.resource.data.experienceDetails.size() <= 2000 &&
        request.resource.data.availability is string &&
        request.resource.data.availability.size() >= 3 &&
        request.resource.data.availability.size() <= 500 &&
        request.resource.data.source == "landing-page-coach" &&
        request.resource.data.createdAt == request.time;
    }

    match /subscriptions/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "goal",
          "planId",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 8 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() >= 3 &&
        request.resource.data.goal.size() <= 40 &&
        request.resource.data.planId is string &&
        request.resource.data.planId.size() >= 4 &&
        request.resource.data.planId.size() <= 40 &&
        request.resource.data.source == "move-web-mvp" &&
        request.resource.data.createdAt == request.time;
    }

    match /injuryReports/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "area",
          "severity",
          "note",
          "status",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.area is string &&
        request.resource.data.area.size() >= 2 &&
        request.resource.data.area.size() <= 80 &&
        request.resource.data.severity is number &&
        request.resource.data.severity >= 1 &&
        request.resource.data.severity <= 3 &&
        request.resource.data.note is string &&
        request.resource.data.note.size() >= 4 &&
        request.resource.data.note.size() <= 1000 &&
        request.resource.data.status == "new" &&
        request.resource.data.source == "move-web-mvp" &&
        request.resource.data.createdAt == request.time;
    }

    match /appConfig/{documentId} {
      allow read: if true;
      allow delete: if false;
      allow create, update: if
        isAdmin() &&
        request.resource.data.keys().hasOnly([
          "workoutPlanVersion",
          "nutritionPlanVersion",
          "featuredWorkoutTitle",
          "featuredWorkoutDurationMin",
          "featuredWorkoutCoach",
          "challengesEnabled",
          "updatedAt",
          "updatedByUid"
        ]) &&
        request.resource.data.workoutPlanVersion is string &&
        request.resource.data.workoutPlanVersion.size() >= 2 &&
        request.resource.data.workoutPlanVersion.size() <= 20 &&
        request.resource.data.nutritionPlanVersion is string &&
        request.resource.data.nutritionPlanVersion.size() >= 2 &&
        request.resource.data.nutritionPlanVersion.size() <= 20 &&
        request.resource.data.featuredWorkoutTitle is string &&
        request.resource.data.featuredWorkoutTitle.size() >= 3 &&
        request.resource.data.featuredWorkoutTitle.size() <= 120 &&
        request.resource.data.featuredWorkoutDurationMin is number &&
        request.resource.data.featuredWorkoutDurationMin >= 5 &&
        request.resource.data.featuredWorkoutDurationMin <= 180 &&
        request.resource.data.featuredWorkoutCoach is string &&
        request.resource.data.featuredWorkoutCoach.size() >= 2 &&
        request.resource.data.featuredWorkoutCoach.size() <= 80 &&
        request.resource.data.challengesEnabled is bool &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }
  }
}
