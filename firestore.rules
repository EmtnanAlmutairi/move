rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    function isCoach() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/coaches/$(request.auth.uid));
    }

    function isPractitioner() {
      return request.auth != null &&
        exists(/databases/$(database)/documents/practitioners/$(request.auth.uid));
    }

    function isAssignedSubscriptionStaff(data) {
      return request.auth != null && (
        data.assignedCoachUid == request.auth.uid ||
        data.assignedNutritionUid == request.auth.uid ||
        data.assignedPhysioUid == request.auth.uid
      );
    }

    function isStaff() {
      return isAdmin() || isCoach() || isPractitioner();
    }

    function hasMemberAssignment(memberUid) {
      return exists(/databases/$(database)/documents/memberAssignments/$(memberUid));
    }

    function isAssignedMemberStaff(memberUid) {
      return request.auth != null &&
        hasMemberAssignment(memberUid) &&
        (
          get(/databases/$(database)/documents/memberAssignments/$(memberUid)).data.assignedCoachUid == request.auth.uid ||
          get(/databases/$(database)/documents/memberAssignments/$(memberUid)).data.assignedNutritionUid == request.auth.uid ||
          get(/databases/$(database)/documents/memberAssignments/$(memberUid)).data.assignedPhysioUid == request.auth.uid
        );
    }

    function canAccessMember(memberUid) {
      return request.auth != null &&
        (
          isAdmin() ||
          request.auth.uid == memberUid ||
          isAssignedMemberStaff(memberUid)
        );
    }

    match /admins/{userId} {
      allow read: if request.auth != null && request.auth.uid == userId;
      allow write: if false;
    }

    match /coaches/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /practitioners/{userId} {
      allow read: if request.auth != null && (request.auth.uid == userId || isAdmin());
      allow create, update, delete: if isAdmin();
    }

    match /memberAssignments/{memberUid} {
      allow read: if canAccessMember(memberUid);
      allow delete: if isAdmin();
      allow create, update: if
        isAdmin() &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "assignedCoachUid",
          "assignedCoachName",
          "assignedNutritionUid",
          "assignedNutritionName",
          "assignedPhysioUid",
          "assignedPhysioName",
          "updatedAt",
          "updatedByUid"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid == memberUid &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        request.resource.data.assignedCoachUid is string &&
        request.resource.data.assignedCoachUid.size() <= 128 &&
        request.resource.data.assignedCoachName is string &&
        request.resource.data.assignedCoachName.size() <= 120 &&
        request.resource.data.assignedNutritionUid is string &&
        request.resource.data.assignedNutritionUid.size() <= 128 &&
        request.resource.data.assignedNutritionName is string &&
        request.resource.data.assignedNutritionName.size() <= 120 &&
        request.resource.data.assignedPhysioUid is string &&
        request.resource.data.assignedPhysioUid.size() <= 128 &&
        request.resource.data.assignedPhysioName is string &&
        request.resource.data.assignedPhysioName.size() <= 120 &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }

    match /memberProfiles/{memberUid} {
      allow read: if canAccessMember(memberUid);
      allow delete: if false;
      allow create, update: if
        request.auth != null &&
        request.auth.uid == memberUid &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "fullName",
          "email",
          "phone",
          "goal",
          "reminderTime",
          "preferredDays",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid == memberUid &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 8 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() >= 3 &&
        request.resource.data.goal.size() <= 40 &&
        request.resource.data.reminderTime is string &&
        request.resource.data.reminderTime.size() <= 8 &&
        request.resource.data.preferredDays is list &&
        request.resource.data.preferredDays.size() <= 7 &&
        request.resource.data.updatedAt == request.time;
    }

    match /memberSchedules/{memberUid} {
      allow read: if canAccessMember(memberUid);
      allow delete: if false;
      allow create, update: if
        request.auth != null &&
        request.auth.uid == memberUid &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "overrides",
          "orderedWorkoutIds",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid == memberUid &&
        request.resource.data.overrides is map &&
        request.resource.data.orderedWorkoutIds is list &&
        request.resource.data.orderedWorkoutIds.size() <= 500 &&
        request.resource.data.updatedAt == request.time;
    }

    match /waitlist/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly(["email", "source", "createdAt"]) &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.source == "landing-page" &&
        request.resource.data.createdAt == request.time;
    }

    match /traineeInterests/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "goal",
          "fitnessLevel",
          "trainingLocation",
          "equipment",
          "healthNotes",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 7 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() >= 3 &&
        request.resource.data.goal.size() <= 40 &&
        request.resource.data.fitnessLevel is string &&
        request.resource.data.fitnessLevel.size() >= 3 &&
        request.resource.data.fitnessLevel.size() <= 20 &&
        request.resource.data.trainingLocation is string &&
        request.resource.data.trainingLocation.size() >= 3 &&
        request.resource.data.trainingLocation.size() <= 20 &&
        request.resource.data.equipment is string &&
        request.resource.data.equipment.size() >= 2 &&
        request.resource.data.equipment.size() <= 1000 &&
        request.resource.data.healthNotes is string &&
        request.resource.data.healthNotes.size() <= 1000 &&
        request.resource.data.source == "landing-page-trainee" &&
        request.resource.data.createdAt == request.time;
    }

    match /coachApplications/{documentId} {
      allow read: if isAdmin();
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "yearsExperience",
          "specialization",
          "sportCategory",
          "certifications",
          "coachingType",
          "coachingLocation",
          "experienceDetails",
          "availability",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 7 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.yearsExperience is number &&
        request.resource.data.yearsExperience >= 0 &&
        request.resource.data.yearsExperience <= 50 &&
        request.resource.data.specialization is string &&
        request.resource.data.specialization.size() >= 3 &&
        request.resource.data.specialization.size() <= 40 &&
        request.resource.data.sportCategory is string &&
        request.resource.data.sportCategory in [
          "strength-muscle",
          "weight-loss-fitness",
          "calisthenics",
          "running-cardio",
          "yoga",
          "pilates",
          "mobility-recovery",
          "rehab-physio"
        ] &&
        request.resource.data.certifications is string &&
        request.resource.data.certifications.size() >= 2 &&
        request.resource.data.certifications.size() <= 300 &&
        request.resource.data.coachingType is string &&
        request.resource.data.coachingType.size() >= 3 &&
        request.resource.data.coachingType.size() <= 20 &&
        request.resource.data.coachingLocation is string &&
        request.resource.data.coachingLocation.size() >= 3 &&
        request.resource.data.coachingLocation.size() <= 30 &&
        request.resource.data.experienceDetails is string &&
        request.resource.data.experienceDetails.size() >= 10 &&
        request.resource.data.experienceDetails.size() <= 2000 &&
        request.resource.data.availability is string &&
        request.resource.data.availability.size() >= 3 &&
        request.resource.data.availability.size() <= 500 &&
        request.resource.data.source == "landing-page-coach" &&
        request.resource.data.createdAt == request.time;
    }

    match /subscriptions/{documentId} {
      allow read: if
        isAdmin() ||
        isAssignedSubscriptionStaff(resource.data) ||
        (request.auth != null && resource.data.memberUid == request.auth.uid);
      allow update: if
        isAdmin() &&
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "goal",
          "planId",
          "memberUid",
          "assignedCoachUid",
          "assignedNutritionUid",
          "assignedPhysioUid",
          "updatedAt",
          "updatedByUid",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 8 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() >= 3 &&
        request.resource.data.goal.size() <= 40 &&
        request.resource.data.planId is string &&
        request.resource.data.planId.size() >= 4 &&
        request.resource.data.planId.size() <= 40 &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        request.resource.data.assignedCoachUid is string &&
        request.resource.data.assignedCoachUid.size() <= 128 &&
        request.resource.data.assignedNutritionUid is string &&
        request.resource.data.assignedNutritionUid.size() <= 128 &&
        request.resource.data.assignedPhysioUid is string &&
        request.resource.data.assignedPhysioUid.size() <= 128 &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedAt == request.time &&
        request.resource.data.source == resource.data.source &&
        request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "fullName",
          "email",
          "phone",
          "goal",
          "planId",
          "memberUid",
          "assignedCoachUid",
          "assignedNutritionUid",
          "assignedPhysioUid",
          "updatedAt",
          "updatedByUid",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.fullName is string &&
        request.resource.data.fullName.size() >= 2 &&
        request.resource.data.fullName.size() <= 120 &&
        request.resource.data.email is string &&
        request.resource.data.email.size() > 5 &&
        request.resource.data.email.size() < 320 &&
        request.resource.data.email.matches("^[^\\s@]+@[^\\s@]+\\.[^\\s@]+$") &&
        request.resource.data.phone is string &&
        request.resource.data.phone.size() >= 8 &&
        request.resource.data.phone.size() <= 24 &&
        request.resource.data.phone.matches("^\\+?[0-9\\-()\\s]{8,24}$") &&
        request.resource.data.goal is string &&
        request.resource.data.goal.size() >= 3 &&
        request.resource.data.goal.size() <= 40 &&
        request.resource.data.planId is string &&
        request.resource.data.planId.size() >= 4 &&
        request.resource.data.planId.size() <= 40 &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        request.resource.data.source == "move-web-mvp" &&
        request.resource.data.createdAt == request.time;
    }

    match /injuryReports/{documentId} {
      allow read: if
        isStaff() ||
        (request.auth != null && resource.data.memberUid == request.auth.uid);
      allow update, delete: if false;
      allow create: if
        request.resource.data.keys().hasOnly([
          "area",
          "severity",
          "note",
          "status",
          "memberUid",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.area is string &&
        request.resource.data.area.size() >= 2 &&
        request.resource.data.area.size() <= 80 &&
        request.resource.data.severity is number &&
        request.resource.data.severity >= 1 &&
        request.resource.data.severity <= 3 &&
        request.resource.data.note is string &&
        request.resource.data.note.size() >= 4 &&
        request.resource.data.note.size() <= 1000 &&
        request.resource.data.status == "new" &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        request.resource.data.source == "move-web-mvp" &&
        request.resource.data.createdAt == request.time;
    }

    match /workoutVideos/{documentId} {
      allow read: if
        request.auth != null &&
        resource.data.memberUid is string &&
        canAccessMember(resource.data.memberUid);
      allow create: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "title",
          "coachName",
          "day",
          "durationMin",
          "intensity",
          "focus",
          "videoUrl",
          "instructions",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        canAccessMember(request.resource.data.memberUid) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.coachName is string &&
        request.resource.data.coachName.size() >= 2 &&
        request.resource.data.coachName.size() <= 120 &&
        request.resource.data.day is string &&
        request.resource.data.day.size() >= 2 &&
        request.resource.data.day.size() <= 30 &&
        request.resource.data.durationMin is number &&
        request.resource.data.durationMin >= 5 &&
        request.resource.data.durationMin <= 180 &&
        request.resource.data.intensity is string &&
        request.resource.data.intensity.size() >= 2 &&
        request.resource.data.intensity.size() <= 20 &&
        request.resource.data.focus is string &&
        request.resource.data.focus.size() >= 3 &&
        request.resource.data.focus.size() <= 20 &&
        request.resource.data.videoUrl is string &&
        request.resource.data.videoUrl.size() <= 1000 &&
        request.resource.data.instructions is string &&
        request.resource.data.instructions.size() <= 2000 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "title",
          "coachName",
          "day",
          "durationMin",
          "intensity",
          "focus",
          "videoUrl",
          "instructions",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        request.resource.data.memberUid == resource.data.memberUid &&
        canAccessMember(request.resource.data.memberUid) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.coachName is string &&
        request.resource.data.coachName.size() >= 2 &&
        request.resource.data.coachName.size() <= 120 &&
        request.resource.data.day is string &&
        request.resource.data.day.size() >= 2 &&
        request.resource.data.day.size() <= 30 &&
        request.resource.data.durationMin is number &&
        request.resource.data.durationMin >= 5 &&
        request.resource.data.durationMin <= 180 &&
        request.resource.data.intensity is string &&
        request.resource.data.intensity.size() >= 2 &&
        request.resource.data.intensity.size() <= 20 &&
        request.resource.data.focus is string &&
        request.resource.data.focus.size() >= 3 &&
        request.resource.data.focus.size() <= 20 &&
        request.resource.data.videoUrl is string &&
        request.resource.data.videoUrl.size() <= 1000 &&
        request.resource.data.instructions is string &&
        request.resource.data.instructions.size() <= 2000 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time;
      allow delete: if
        isStaff() &&
        resource.data.memberUid is string &&
        canAccessMember(resource.data.memberUid);
    }

    match /nutritionMeals/{documentId} {
      allow read: if
        request.auth != null &&
        resource.data.memberUid is string &&
        canAccessMember(resource.data.memberUid);
      allow create: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "title",
          "time",
          "kcal",
          "protein",
          "carbs",
          "fat",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        canAccessMember(request.resource.data.memberUid) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.time is string &&
        request.resource.data.time.size() >= 2 &&
        request.resource.data.time.size() <= 30 &&
        request.resource.data.kcal is number &&
        request.resource.data.kcal >= 0 &&
        request.resource.data.kcal <= 3000 &&
        request.resource.data.protein is number &&
        request.resource.data.protein >= 0 &&
        request.resource.data.protein <= 300 &&
        request.resource.data.carbs is number &&
        request.resource.data.carbs >= 0 &&
        request.resource.data.carbs <= 400 &&
        request.resource.data.fat is number &&
        request.resource.data.fat >= 0 &&
        request.resource.data.fat <= 300 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "title",
          "time",
          "kcal",
          "protein",
          "carbs",
          "fat",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        request.resource.data.memberUid == resource.data.memberUid &&
        canAccessMember(request.resource.data.memberUid) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.time is string &&
        request.resource.data.time.size() >= 2 &&
        request.resource.data.time.size() <= 30 &&
        request.resource.data.kcal is number &&
        request.resource.data.kcal >= 0 &&
        request.resource.data.kcal <= 3000 &&
        request.resource.data.protein is number &&
        request.resource.data.protein >= 0 &&
        request.resource.data.protein <= 300 &&
        request.resource.data.carbs is number &&
        request.resource.data.carbs >= 0 &&
        request.resource.data.carbs <= 400 &&
        request.resource.data.fat is number &&
        request.resource.data.fat >= 0 &&
        request.resource.data.fat <= 300 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time;
      allow delete: if
        isStaff() &&
        resource.data.memberUid is string &&
        canAccessMember(resource.data.memberUid);
    }

    match /communityPosts/{documentId} {
      allow read: if true;
      allow create: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "title",
          "body",
          "authorRole",
          "createdByUid",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.body is string &&
        request.resource.data.body.size() >= 4 &&
        request.resource.data.body.size() <= 3000 &&
        request.resource.data.authorRole is string &&
        request.resource.data.authorRole.size() >= 2 &&
        request.resource.data.authorRole.size() <= 80 &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.source is string &&
        request.resource.data.source.size() >= 3 &&
        request.resource.data.source.size() <= 40 &&
        request.resource.data.createdAt == request.time;
      allow update: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "title",
          "body",
          "authorRole",
          "createdByUid",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.body is string &&
        request.resource.data.body.size() >= 4 &&
        request.resource.data.body.size() <= 3000 &&
        request.resource.data.authorRole is string &&
        request.resource.data.authorRole.size() >= 2 &&
        request.resource.data.authorRole.size() <= 80 &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.source == resource.data.source &&
        request.resource.data.createdAt == resource.data.createdAt;
      allow delete: if isStaff();
    }

    match /supportMessages/{documentId} {
      allow read: if
        request.auth != null &&
        (isStaff() || resource.data.threadId == request.auth.uid);

      allow create: if
        request.auth != null &&
        request.resource.data.keys().hasOnly([
          "threadId",
          "senderRole",
          "targetRole",
          "senderName",
          "text",
          "source",
          "createdAt"
        ]) &&
        request.resource.data.threadId is string &&
        request.resource.data.threadId.size() >= 4 &&
        request.resource.data.threadId.size() <= 128 &&
        request.resource.data.senderRole is string &&
        request.resource.data.senderRole.size() >= 4 &&
        request.resource.data.senderRole.size() <= 20 &&
        request.resource.data.targetRole is string &&
        request.resource.data.targetRole.size() >= 0 &&
        request.resource.data.targetRole.size() <= 20 &&
        request.resource.data.senderName is string &&
        request.resource.data.senderName.size() >= 2 &&
        request.resource.data.senderName.size() <= 120 &&
        request.resource.data.text is string &&
        request.resource.data.text.size() >= 1 &&
        request.resource.data.text.size() <= 2000 &&
        request.resource.data.source is string &&
        request.resource.data.source.size() >= 3 &&
        request.resource.data.source.size() <= 40 &&
        request.resource.data.createdAt == request.time &&
        (
          (
            isStaff() &&
            (
              request.resource.data.senderRole == "coach" ||
              request.resource.data.senderRole == "nutrition" ||
              request.resource.data.senderRole == "physio"
            ) &&
            request.resource.data.targetRole == "member"
          ) ||
          (
            request.resource.data.threadId == request.auth.uid &&
            request.resource.data.senderRole == "member" &&
            (
              request.resource.data.targetRole == "coach" ||
              request.resource.data.targetRole == "nutrition" ||
              request.resource.data.targetRole == "physio"
            )
          )
        );

      allow update, delete: if false;
    }

    match /payouts/{documentId} {
      allow read: if
        request.auth != null &&
        (
          isAdmin() ||
          resource.data.specialistUid == request.auth.uid
        );
      allow delete: if false;
      allow create: if
        isAdmin() &&
        request.resource.data.keys().hasOnly([
          "month",
          "role",
          "specialistUid",
          "grossRevenue",
          "shareRate",
          "payoutAmount",
          "status",
          "paidAt",
          "updatedAt",
          "updatedByUid"
        ]) &&
        request.resource.data.month is string &&
        request.resource.data.month.matches("^\\d{4}-\\d{2}$") &&
        request.resource.data.role is string &&
        request.resource.data.role.size() >= 4 &&
        request.resource.data.role.size() <= 20 &&
        request.resource.data.specialistUid is string &&
        request.resource.data.specialistUid.size() >= 4 &&
        request.resource.data.specialistUid.size() <= 128 &&
        request.resource.data.grossRevenue is number &&
        request.resource.data.grossRevenue >= 0 &&
        request.resource.data.shareRate is number &&
        request.resource.data.shareRate >= 0 &&
        request.resource.data.shareRate <= 1 &&
        request.resource.data.payoutAmount is number &&
        request.resource.data.payoutAmount >= 0 &&
        request.resource.data.status is string &&
        (
          request.resource.data.status == "pending" ||
          request.resource.data.status == "paid"
        ) &&
        (
          request.resource.data.paidAt == null ||
          request.resource.data.paidAt == request.time
        ) &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedAt == request.time;

      allow update: if
        isAdmin() &&
        request.resource.data.keys().hasOnly([
          "month",
          "role",
          "specialistUid",
          "grossRevenue",
          "shareRate",
          "payoutAmount",
          "status",
          "paidAt",
          "updatedAt",
          "updatedByUid"
        ]) &&
        request.resource.data.month is string &&
        request.resource.data.month.matches("^\\d{4}-\\d{2}$") &&
        request.resource.data.role is string &&
        request.resource.data.role.size() >= 4 &&
        request.resource.data.role.size() <= 20 &&
        request.resource.data.specialistUid is string &&
        request.resource.data.specialistUid.size() >= 4 &&
        request.resource.data.specialistUid.size() <= 128 &&
        request.resource.data.grossRevenue is number &&
        request.resource.data.grossRevenue >= 0 &&
        request.resource.data.shareRate is number &&
        request.resource.data.shareRate >= 0 &&
        request.resource.data.shareRate <= 1 &&
        request.resource.data.payoutAmount is number &&
        request.resource.data.payoutAmount >= 0 &&
        request.resource.data.status is string &&
        (
          request.resource.data.status == "pending" ||
          request.resource.data.status == "paid"
        ) &&
        (
          request.resource.data.paidAt == null ||
          request.resource.data.paidAt == request.time ||
          request.resource.data.paidAt == resource.data.paidAt
        ) &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }

    match /specialistProfiles/{userId} {
      allow read: if request.auth != null;
      allow delete: if false;
      allow create, update: if
        request.auth != null &&
        (request.auth.uid == userId || isAdmin()) &&
        request.resource.data.keys().hasOnly([
          "uid",
          "role",
          "displayName",
          "specialization",
          "yearsExperience",
          "certifications",
          "bio",
          "updatedAt"
        ]) &&
        request.resource.data.uid is string &&
        request.resource.data.uid == userId &&
        request.resource.data.role is string &&
        request.resource.data.role.size() >= 4 &&
        request.resource.data.role.size() <= 20 &&
        request.resource.data.displayName is string &&
        request.resource.data.displayName.size() >= 2 &&
        request.resource.data.displayName.size() <= 120 &&
        request.resource.data.specialization is string &&
        request.resource.data.specialization.size() >= 2 &&
        request.resource.data.specialization.size() <= 120 &&
        request.resource.data.yearsExperience is number &&
        request.resource.data.yearsExperience >= 0 &&
        request.resource.data.yearsExperience <= 60 &&
        request.resource.data.certifications is string &&
        request.resource.data.certifications.size() <= 500 &&
        request.resource.data.bio is string &&
        request.resource.data.bio.size() <= 2000 &&
        request.resource.data.updatedAt == request.time;
    }

    match /workoutLibrary/{documentId} {
      allow read: if
        isStaff() &&
        (
          isAdmin() ||
          resource.data.createdByUid == request.auth.uid
        );
      allow create: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "title",
          "defaultDay",
          "durationMin",
          "intensity",
          "focus",
          "videoUrl",
          "instructions",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.defaultDay is string &&
        request.resource.data.defaultDay.size() >= 2 &&
        request.resource.data.defaultDay.size() <= 30 &&
        request.resource.data.durationMin is number &&
        request.resource.data.durationMin >= 5 &&
        request.resource.data.durationMin <= 180 &&
        request.resource.data.intensity is string &&
        request.resource.data.intensity.size() >= 2 &&
        request.resource.data.intensity.size() <= 20 &&
        request.resource.data.focus is string &&
        request.resource.data.focus.size() >= 3 &&
        request.resource.data.focus.size() <= 30 &&
        request.resource.data.videoUrl is string &&
        request.resource.data.videoUrl.size() >= 8 &&
        request.resource.data.videoUrl.size() <= 1000 &&
        request.resource.data.instructions is string &&
        request.resource.data.instructions.size() <= 2000 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "title",
          "defaultDay",
          "durationMin",
          "intensity",
          "focus",
          "videoUrl",
          "instructions",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.defaultDay is string &&
        request.resource.data.defaultDay.size() >= 2 &&
        request.resource.data.defaultDay.size() <= 30 &&
        request.resource.data.durationMin is number &&
        request.resource.data.durationMin >= 5 &&
        request.resource.data.durationMin <= 180 &&
        request.resource.data.intensity is string &&
        request.resource.data.intensity.size() >= 2 &&
        request.resource.data.intensity.size() <= 20 &&
        request.resource.data.focus is string &&
        request.resource.data.focus.size() >= 3 &&
        request.resource.data.focus.size() <= 30 &&
        request.resource.data.videoUrl is string &&
        request.resource.data.videoUrl.size() >= 8 &&
        request.resource.data.videoUrl.size() <= 1000 &&
        request.resource.data.instructions is string &&
        request.resource.data.instructions.size() <= 2000 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        (
          isAdmin() ||
          resource.data.createdByUid == request.auth.uid
        ) &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time;
      allow delete: if
        isStaff() &&
        (
          isAdmin() ||
          resource.data.createdByUid == request.auth.uid
        );
    }

    match /nutritionTemplates/{documentId} {
      allow read: if
        isStaff() &&
        (
          isAdmin() ||
          resource.data.createdByUid == request.auth.uid
        );
      allow create: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "templateName",
          "caseType",
          "weekDay",
          "title",
          "time",
          "kcal",
          "protein",
          "carbs",
          "fat",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.templateName is string &&
        request.resource.data.templateName.size() >= 2 &&
        request.resource.data.templateName.size() <= 120 &&
        request.resource.data.caseType is string &&
        request.resource.data.caseType.size() >= 3 &&
        request.resource.data.caseType.size() <= 40 &&
        request.resource.data.weekDay is string &&
        request.resource.data.weekDay.size() >= 2 &&
        request.resource.data.weekDay.size() <= 30 &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.time is string &&
        request.resource.data.time.size() >= 2 &&
        request.resource.data.time.size() <= 30 &&
        request.resource.data.kcal is number &&
        request.resource.data.kcal >= 0 &&
        request.resource.data.kcal <= 3000 &&
        request.resource.data.protein is number &&
        request.resource.data.protein >= 0 &&
        request.resource.data.protein <= 300 &&
        request.resource.data.carbs is number &&
        request.resource.data.carbs >= 0 &&
        request.resource.data.carbs <= 400 &&
        request.resource.data.fat is number &&
        request.resource.data.fat >= 0 &&
        request.resource.data.fat <= 300 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        request.resource.data.createdByUid == request.auth.uid &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "templateName",
          "caseType",
          "weekDay",
          "title",
          "time",
          "kcal",
          "protein",
          "carbs",
          "fat",
          "sortOrder",
          "createdByUid",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.templateName is string &&
        request.resource.data.templateName.size() >= 2 &&
        request.resource.data.templateName.size() <= 120 &&
        request.resource.data.caseType is string &&
        request.resource.data.caseType.size() >= 3 &&
        request.resource.data.caseType.size() <= 40 &&
        request.resource.data.weekDay is string &&
        request.resource.data.weekDay.size() >= 2 &&
        request.resource.data.weekDay.size() <= 30 &&
        request.resource.data.title is string &&
        request.resource.data.title.size() >= 2 &&
        request.resource.data.title.size() <= 140 &&
        request.resource.data.time is string &&
        request.resource.data.time.size() >= 2 &&
        request.resource.data.time.size() <= 30 &&
        request.resource.data.kcal is number &&
        request.resource.data.kcal >= 0 &&
        request.resource.data.kcal <= 3000 &&
        request.resource.data.protein is number &&
        request.resource.data.protein >= 0 &&
        request.resource.data.protein <= 300 &&
        request.resource.data.carbs is number &&
        request.resource.data.carbs >= 0 &&
        request.resource.data.carbs <= 400 &&
        request.resource.data.fat is number &&
        request.resource.data.fat >= 0 &&
        request.resource.data.fat <= 300 &&
        request.resource.data.sortOrder is number &&
        request.resource.data.sortOrder >= 1 &&
        request.resource.data.sortOrder <= 999 &&
        (
          isAdmin() ||
          resource.data.createdByUid == request.auth.uid
        ) &&
        request.resource.data.createdByUid == resource.data.createdByUid &&
        request.resource.data.createdAt == resource.data.createdAt &&
        request.resource.data.updatedAt == request.time;
      allow delete: if
        isStaff() &&
        (
          isAdmin() ||
          resource.data.createdByUid == request.auth.uid
        );
    }

    match /injuryFollowups/{documentId} {
      allow read: if
        request.auth != null &&
        resource.data.memberUid is string &&
        canAccessMember(resource.data.memberUid);
      allow create: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "memberUid",
          "injuryId",
          "status",
          "plan",
          "nextCheckDate",
          "specialistUid",
          "specialistRole",
          "createdAt",
          "updatedAt"
        ]) &&
        request.resource.data.memberUid is string &&
        request.resource.data.memberUid.size() >= 4 &&
        request.resource.data.memberUid.size() <= 128 &&
        canAccessMember(request.resource.data.memberUid) &&
        request.resource.data.injuryId is string &&
        request.resource.data.injuryId.size() <= 128 &&
        request.resource.data.status is string &&
        request.resource.data.status.size() >= 3 &&
        request.resource.data.status.size() <= 40 &&
        request.resource.data.plan is string &&
        request.resource.data.plan.size() >= 4 &&
        request.resource.data.plan.size() <= 2500 &&
        request.resource.data.nextCheckDate is string &&
        request.resource.data.nextCheckDate.size() <= 20 &&
        request.resource.data.specialistUid == request.auth.uid &&
        request.resource.data.specialistRole is string &&
        request.resource.data.specialistRole.size() >= 4 &&
        request.resource.data.specialistRole.size() <= 20 &&
        request.resource.data.createdAt == request.time &&
        request.resource.data.updatedAt == request.time;
      allow update, delete: if false;
    }

    match /appConfig/{documentId} {
      allow read: if true;
      allow delete: if false;
      allow create, update: if
        isStaff() &&
        request.resource.data.keys().hasOnly([
          "workoutPlanVersion",
          "nutritionPlanVersion",
          "featuredWorkoutTitle",
          "featuredWorkoutDurationMin",
          "featuredWorkoutCoach",
          "challengesEnabled",
          "updatedAt",
          "updatedByUid"
        ]) &&
        request.resource.data.workoutPlanVersion is string &&
        request.resource.data.workoutPlanVersion.size() >= 2 &&
        request.resource.data.workoutPlanVersion.size() <= 20 &&
        request.resource.data.nutritionPlanVersion is string &&
        request.resource.data.nutritionPlanVersion.size() >= 2 &&
        request.resource.data.nutritionPlanVersion.size() <= 20 &&
        request.resource.data.featuredWorkoutTitle is string &&
        request.resource.data.featuredWorkoutTitle.size() >= 3 &&
        request.resource.data.featuredWorkoutTitle.size() <= 120 &&
        request.resource.data.featuredWorkoutDurationMin is number &&
        request.resource.data.featuredWorkoutDurationMin >= 5 &&
        request.resource.data.featuredWorkoutDurationMin <= 180 &&
        request.resource.data.featuredWorkoutCoach is string &&
        request.resource.data.featuredWorkoutCoach.size() >= 2 &&
        request.resource.data.featuredWorkoutCoach.size() <= 80 &&
        request.resource.data.challengesEnabled is bool &&
        request.resource.data.updatedByUid == request.auth.uid &&
        request.resource.data.updatedAt == request.time;
    }
  }
}
